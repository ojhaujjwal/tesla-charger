{
  "printWidth": 120,
  "tabWidth": 2,
  "useTabs": false,
  "semi": true,
  "singleQuote": false,
  "trailingComma": "none",
  "arrowParens": "always",
  "jsxSingleQuote": false,
  "ignorePatterns": [
    "**/node_modules/**",
    "**/dist/**",
    "**/build/**",
    "**/.tsbuildinfo",
    "**/*.md",
    "**/.ralph/**",
    "repos/**"
  ]
}
