{
  "ignorePatterns": [
    "**/node_modules/**",
    "**/dist/**",
    "**/build/**",
    "**/.tsbuildinfo",
    "**/*.md",
    "**/.ralph/**",
    "repos/**",
    ".opencode/plugin/**"
  ],
  "jsPlugins": ["@ojhaujjwal/effect-backpressure/oxlint"],
  "extends": ["./node_modules/@ojhaujjwal/effect-backpressure/configs/strict.json"],
  "rules": {
    "no-explicit-any": "error",
    "typescript/consistent-type-assertions": ["error", { "assertionStyle": "never" }],
    "typescript/no-non-null-assertion": "error",
    "effect-lint/no-raw-date": "off",
    "effect-lint/no-async-await": "error"
  },
  "overrides": [
    {
      "files": ["**/*.test.ts"],
      "rules": {
        "effect-lint/no-silent-error-swallow": "off"
      }
    },
    {
      "files": ["src/setup-tesla-partner-application.ts"],
      "rules": {
        "effect-lint/no-console": "off"
      }
    },
    {
      "files": ["src/memory-usage.ts"],
      "rules": {
        "effect-lint/no-process": "off"
      }
    },
    {
      "files": ["src/generate-refresh-token.ts"],
      "rules": {
        "effect-lint/no-process": "off"
      }
    },
    {
      "files": ["src/http-server-layer.ts"],
      "rules": {
        "effect-lint/no-node-imports": "off"
      }
    }
  ]
}
