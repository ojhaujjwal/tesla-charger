{
  "name": "tesla-charger",
  "version": "1.0.0",
  "description": "",
  "license": "ISC",
  "author": "",
  "type": "module",
  "exports": "./index.js",
  "scripts": {
    "cmd:generate-refresh-token": "tsx --env-file=.env src/generate-refresh-token.ts",
    "cmd:setup-tesla-partner-application": "tsx --env-file=.env src/setup-tesla-partner-application.ts",
    "ci": "npm run typecheck && npm run lint && npm run test -- --run && npm run format-fix",
    "test": "vitest src/",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "dev": "tsx  --env-file=.env src/main.ts",
    "lint": "NODE_OPTIONS='--import tsx/esm' oxlint --disable-nested-config",
    "lint:fix": "NODE_OPTIONS='--import tsx/esm' oxlint --disable-nested-config --fix",
    "format": "oxfmt --check",
    "format-fix": "oxfmt --write",
    "start": "pm2 start ecosystem.config.cjs",
    "restart": "pm2 restart ecosystem.config.cjs",
    "stop": "pm2 stop ecosystem.config.cjs",
    "logs": "pm2 logs",
    "lint-staged": "lint-staged",
    "prepare": "husky && effect-language-service patch"
  },
  "dependencies": {
    "@effect/platform-node": "^4.0.0-beta.66",
    "effect": "^4.0.0-beta.66",
    "pm2": "^5.4.3"
  },
  "devDependencies": {
    "@effect/language-service": "^0.86.1",
    "@effect/vitest": "^4.0.0-beta.66",
    "@ojhaujjwal/effect-backpressure": "^0.0.3",
    "@types/node": "^22.10.2",
    "@vitest/coverage-v8": "^3.0.5",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "pino-test": "^1.1.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^3.0.5"
  },
  "engines": {
    "node": ">=21.7.3"
  }
}
